{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true,
    "maxWarnings": 0
  },
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "node",
    "vitest"
  ],
  "rules": {
    "vitest/expect-expect": "off"
  }
}
